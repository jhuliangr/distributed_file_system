{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["es2023"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "types": ["node"],

    "strict": true,
    "noUncheckedIndexedAccess": false,
    "skipLibCheck": true,

    // Run .ts directly with Node's type stripping — no emit, import with .ts
    // extensions, and forbid syntax that can't be erased (enums, namespaces…).
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true
  },
  "include": ["src", "test"]
}
